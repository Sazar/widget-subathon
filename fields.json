  "timePerSubT3":    { "type": "number",   "label": "⏱ Secondes / Sub Tier 3",             "value": 900,  "step": 1, "min": 0 },
  "timePerSubPrime": { "type": "number",   "label": "⏱ Secondes / Sub Prime",              "value": 300,  "step": 1, "min": 0 },

