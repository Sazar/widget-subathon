{
  "initialTime": {
    "type": "text",
    "label": "⏱ Temps initial (HH:MM:SS)",
    "value": "01:00:00"
  },
  "maxTime": {
    "type": "text",
    "label": "⏳ Temps maximum (HH:MM:SS) — 00:00:00 = aucune limite",
    "value": "00:00:00"
  },
  "autoStart": {
    "type": "checkbox",
    "label": "▶️ Démarrer le timer automatiquement au chargement",
    "value": true
  },
  "lockOnZero": {
    "type": "checkbox",
    "label": "🔒 Bloquer l'ajout de temps si le timer est à 0",
    "value": false
  },

  "subEnabled":      { "type": "checkbox", "label": "✅ Activer : Subs",                    "value": true },
  "timePerSubT1":    { "type": "number",   "label": "⏱ Secondes / Sub Tier 1",             "value": 300,  "step": 1, "min": 0 },
  "timePerSubT2":    { "type": "number",   "label": "⏱ Secondes / Sub Tier 2",             "value": 600,  "step": 1, "min": 0 },
  "timePerSubT3":    { "type": "number",   "label": "⏱ Secondes / Sub Tier 3",             "value": 900,  "step": 1, "min": 0 },
  "timePerSubPrime": { "type": "number",   "label": "⏱ Secondes / Sub Prime",              "value": 300,  "step": 1, "min": 0 },

  "resubEnabled":      { "type": "checkbox", "label": "✅ Activer : Resubs",                "value": true },
  "timePerResubT1":    { "type": "number",   "label": "⏱ Secondes / Resub Tier 1",         "value": 180,  "step": 1, "min": 0 },
  "timePerResubT2":    { "type": "number",   "label": "⏱ Secondes / Resub Tier 2",         "value": 360,  "step": 1, "min": 0 },
  "timePerResubT3":    { "type": "number",   "label": "⏱ Secondes / Resub Tier 3",         "value": 540,  "step": 1, "min": 0 },
  "timePerResubPrime": { "type": "number",   "label": "⏱ Secondes / Resub Prime",          "value": 180,  "step": 1, "min": 0 },

  "giftEnabled":     { "type": "checkbox", "label": "✅ Activer : Gift Subs",               "value": true },
  "timePerGiftT1":   { "type": "number",   "label": "⏱ Secondes / Gift Sub Tier 1",        "value": 300,  "step": 1, "min": 0 },
  "timePerGiftT2":   { "type": "number",   "label": "⏱ Secondes / Gift Sub Tier 2",        "value": 600,  "step": 1, "min": 0 },
  "timePerGiftT3":   { "type": "number",   "label": "⏱ Secondes / Gift Sub Tier 3",        "value": 900,  "step": 1, "min": 0 },

  "donoEnabled":    { "type": "checkbox", "label": "✅ Activer : Dons",                    "value": true },
  "timePerDono":    { "type": "number",   "label": "⏱ Secondes / tranche de don",         "value": 60,   "step": 1, "min": 0 },
  "timePerDonoPer": { "type": "number",   "label": "💶 Tranche don (€)",                  "value": 5,    "step": 1, "min": 1 },

  "bitsEnabled":    { "type": "checkbox", "label": "✅ Activer : Bits",                    "value": true },
  "timePerBits":    { "type": "number",   "label": "⏱ Secondes / tranche bits",           "value": 30,   "step": 1, "min": 0 },
  "timePerBitsPer": { "type": "number",   "label": "💎 Tranche bits",                     "value": 100,  "step": 1, "min": 1 },

  "followEnabled":  { "type": "checkbox", "label": "✅ Activer : Follows",                "value": true },
  "timePerFollow":  { "type": "number",   "label": "⏱ Secondes / Follow",                "value": 15,   "step": 1, "min": 0 },

  "goalEnabled": { "type": "checkbox", "label": "🎯 Afficher Goal Box", "value": true },
  "goalType": {
    "type": "dropdown", "label": "🎯 Type de goal",
    "value": "sub",
    "options": { "sub": "Subs", "dono": "Dons (€)", "bits": "Bits" }
  },
  "goalTarget": { "type": "number", "label": "🎯 Objectif cible", "value": 50, "step": 1, "min": 1 },

  "cmdEnabled": {
    "type": "checkbox",
    "label": "💬 Activer les commandes chat",
    "value": true
  },
  "cmdPrefix": {
    "type": "text",
    "label": "💬 Préfixe commandes",
    "value": "!"
  },
  "cmdStart": {
    "type": "text",
    "label": "💬 Alias Démarrer le timer",
    "value": "start"
  },
  "cmdStop": {
    "type": "text",
    "label": "💬 Alias Mettre en pause",
    "value": "stop"
  },
  "cmdReset": {
    "type": "text",
    "label": "💬 Alias Remettre à zéro",
    "value": "reset"
  },
  "cmdSetTime": {
    "type": "text",
    "label": "💬 Alias Définir le temps (ex: !settime 01:30:00)",
    "value": "settime"
  },
  "cmdAddTime": {
    "type": "text",
    "label": "💬 Alias Ajouter du temps (ex: !addtime 00:05:00 ou !addtime 300)",
    "value": "addtime"
  },
  "cmdRemoveTime": {
    "type": "text",
    "label": "💬 Alias Retirer du temps (ex: !removetime 00:05:00 ou !removetime 300)",
    "value": "removetime"
  },
  "cmdModOnly": {
    "type": "checkbox",
    "label": "🛡️ Commandes réservées aux mods & streamer uniquement",
    "value": true
  },

  "widgetFont": {
    "type": "dropdown",
    "label": "🔤 Police globale (toutes les box)",
    "value": "Rajdhani",
    "options": {
      "Rajdhani":         "Rajdhani (défaut)",
      "Exo 2":            "Exo 2",
      "Oswald":           "Oswald",
      "Bebas Neue":       "Bebas Neue",
      "Anton":            "Anton",
      "Barlow Condensed": "Barlow Condensed",
      "Teko":             "Teko",
      "Russo One":        "Russo One",
      "Orbitron":         "Orbitron",
      "Play":             "Play"
    }
  },

  "alertFontSize": { "type": "number", "label": "🔤 Taille police Event (px)",     "value": 42, "step": 1, "min": 12 },
  "timerFontSize": { "type": "slider", "label": "⏱ Timer — taille du texte (px)", "value": 36, "min": 20, "max": 80, "steps": 1 },

  "widgetWidth":   { "type": "text",   "label": "📐 Largeur widget",              "value": "520px" },
  "accent":        { "type": "color",  "label": "🎨 Couleur accent",              "value": "#e84118" },

  "boxBgColor":    { "type": "color",  "label": "🎨 Alert Box — couleur fond",     "value": "#0e0e14" },
  "boxBgOpacity":  { "type": "slider", "label": "🎨 Alert Box — opacité fond",    "value": 82, "min": 0, "max": 100, "steps": 1 },

  "timerBg":       { "type": "color",  "label": "🎨 Timer — fond",                 "value": "#e84118" },
  "timerText":     { "type": "color",  "label": "🎨 Timer — texte",                "value": "#ffffff" },

  "goalBgColor":   { "type": "color",  "label": "🎨 Goal Box — couleur fond",      "value": "#0c0c14" },
  "goalBgOpacity": { "type": "slider", "label": "🎨 Goal Box — opacité fond",     "value": 90, "min": 0, "max": 100, "steps": 1 },
  "goalText":      { "type": "color",  "label": "🎨 Goal Box — texte",             "value": "#ffffff" },

  "infoBg":        { "type": "color",  "label": "🎨 Info Box — fond",              "value": "#e84118" },
  "infoText":      { "type": "color",  "label": "🎨 Info Box — texte",             "value": "#ffffff" },
  "glowColor":     { "type": "color",  "label": "🎨 Info Box — couleur glow",     "value": "#e84118" },
  "glowOpacity":   { "type": "slider", "label": "🎨 Info Box — intensité glow",  "value": 45, "min": 0, "max": 100, "steps": 1 }
}
